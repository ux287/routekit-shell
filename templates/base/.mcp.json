{
  "mcpServers": {
    "rks": {
      "command": "node",
      "args": ["__ROUTEKIT_SHELL_ROOT__/packages/mcp-rks/bin/mcp-rks.mjs"],
      "env": {
        "ROUTEKIT_PROJECT_ID": "__ROUTEKIT_PROJECT_ID__",
        "ROUTEKIT_PROJECT_ROOT": "__ROUTEKIT_PROJECT_ROOT__"
      }
    },
    "github": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env ] && . ./.env; set +a; exec npx -y @modelcontextprotocol/server-github"
      ]
    }
  }
}
