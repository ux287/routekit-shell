# LLM provider credentials
# Copy this file to `.env` and fill in your keys. Do not commit the `.env` file.
#   cp .env.example .env

ROUTEKIT_LLM_PROVIDER=anthropic
ROUTEKIT_LLM_MODEL=claude-sonnet-4-6
# Latest models: https://docs.anthropic.com/en/docs/about-claude/models/overview
# claude-sonnet-4-6 is the recommended default. Adjust to taste — Haiku for lower
# cost/latency, Opus for maximum capability. The full range: Haiku → Sonnet → Opus.
ANTHROPIC_API_KEY=

# If using OpenAI instead of Anthropic, override provider/model and set the key:
# ROUTEKIT_LLM_PROVIDER=openai
# ROUTEKIT_LLM_MODEL=gpt-5.1-codex-mini
# OPENAI_API_KEY=

# ROUTEKIT_LLM_PROVIDER is optional — the runtime infers the provider from whichever
# API key is set. Only specify it if both keys are present and you need to force one.

# Web search (optional) — used by the Research Agent for external lookups
# Obtain a key at https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=

# GitHub integration (optional) — enables PR creation and CI status polling
# GITHUB_TOKEN=

# GitHub Personal Access Token — use this instead of GITHUB_TOKEN when fine-grained
# scopes are needed (e.g., writing to private repos or accessing org-level APIs).
# For most workflows GITHUB_TOKEN is sufficient; set GITHUB_PERSONAL_ACCESS_TOKEN
# only when the standard token lacks the required permissions.
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Never commit your .env file — it contains real credentials.
