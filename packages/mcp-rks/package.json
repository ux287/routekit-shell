{
  "name": "@routekit/mcp-rks",
  "version": "0.27.2",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "src/server.mjs",
  "bin": {
    "mcp-rks": "bin/mcp-rks.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "start": "node bin/mcp-rks.mjs",
    "build": "echo \"no build step\"",
    "link": "npm link",
    "dev": "node src/server.mjs",
    "dev:link": "npm run link && npm run dev",
    "test": "node --test __tests__/*.spec.mjs src/server/*.spec.mjs",
    "test:contract": "node --test __tests__/mcp-contract.spec.mjs",
    "test:golden": "node --test __tests__/golden-replay.spec.mjs",
    "test:eval-telemetry": "node --test __tests__/eval-telemetry.spec.mjs",
    "rag:init": "node ../../scripts/rag/init.mjs || true",
    "rag:embed": "node ../../scripts/rag/embed.mjs || true"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.21.3",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "zod": "^3.25.76",
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
